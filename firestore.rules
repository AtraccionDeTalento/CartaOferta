rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Colecciones operativas — solo usuarios autenticados
    match /solicitudes_ingreso/{docId} {
      allow read, write: if request.auth != null;
    }
    match /cartas_oferta/{docId} {
      allow read, write: if request.auth != null;
    }
    match /movimientos/{docId} {
      allow read, write: if request.auth != null;
    }

    // Catálogos — lectura pública, escritura solo autenticados
    match /catalogos/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Usuarios / perfiles — cada usuario solo lee/escribe el suyo
    match /usuarios/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Denegar todo lo demás
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
